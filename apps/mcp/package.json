{
  "name": "mcp",
  "version": "1.0.0",
  "description": "MCP server for Edit Mind – search video scenes and view media",
  "type": "module",
  "bin": {
    "edit-mind-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "bundle": "node bundle.mjs",
    "dev": "node --import tsx/esm src/index.ts",
    "start": "node dist/index.js",
    "test": "node --import tsx/esm --test tests/tools/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  }
}
